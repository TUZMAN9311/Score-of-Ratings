<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="ScoreOfRatings.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:ScoreOfRatings"
    Title="ScoreOfRatings">

    <ShellContent
        Title="5 бальная система"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />
    <ShellContent
        Title="10 бальная система"
        ContentTemplate="{DataTemplate local:SecondPage}"
        Route="SecondPage" />
    <ShellContent
        Title="12 бальная система"
        ContentTemplate="{DataTemplate local:ThirdPage}"
        Route="ThirdPage" />
    <ShellContent
        Title="Контакты"
        ContentTemplate="{DataTemplate local:ContactPage}"
        Route="ContactPage"/>
</Shell>
