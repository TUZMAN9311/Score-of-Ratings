<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ScoreOfRatings.ContactPage">
    
    <Grid RowDefinitions="Auto, Auto, Auto, Auto" ColumnDefinitions="*" Padding="20">
        <Button
            Text="Youtube"
            Clicked="YoutubeButtonClicked"
            Grid.Row="0"
            Grid.Column="0"/>
        <Button
            Text="Twitch"
            Clicked="TwitchButtonClicked"
            Grid.Row="1"
            Grid.Column="0"
            Margin="0, 20, 0, 0"/>
        <Button
            Text="Kick"
            Clicked="KickButtonClicked"
            Grid.Row="2"
            Grid.Column="0"
            Margin="0, 20, 0, 0"/>
        <Button
            Text="GitHub"
            Clicked="GitHubButtonClicked"
            Grid.Row="3"
            Grid.Column="0"
            Margin="0, 20, 0, 0"/>
    </Grid>
</ContentPage>