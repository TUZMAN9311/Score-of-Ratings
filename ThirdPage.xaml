                x:Name="Button"
                Text="Посчитать"
                Clicked="OnMyButtonClick"
                Grid.Row="7"
                Grid.ColumnSpan="4"
                FontSize="20"/>
            <Label
                x:Name="Result2"
                Grid.Row="8"
                Grid.ColumnSpan="4"
                FontSize="20"
                HorizontalOptions="Center"
                Margin="0, 20, 0, 0"
                FontAttributes="Bold"/>
            <Label
                x:Name="Result3"
                Grid.Row="9"
                Grid.ColumnSpan="4"
                FontSize="20"
                HorizontalOptions="Center"
                Margin="0, 20, 0, 0"
