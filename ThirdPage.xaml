                Text="9"
                Grid.Row="1"
                Grid.Column="3"
                HorizontalOptions="Center"
                FontSize="20"
                Margin="0,35,0,0"/>
            <Entry
                x:Name="grade12"
                Grid.Row="2"
                Grid.Column="0"
                HorizontalOptions="Center"
                VerticalOptions="Start"
                FontSize="15"
                HorizontalTextAlignment="Center"
